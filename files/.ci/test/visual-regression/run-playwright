#!/bin/bash
set -e  # Exit on any error

#
# This script runs visual regression tests using Playwright's built-in testing tools
#

# Debug: Print environment variables
echo "=== Environment Variables in Run Script ==="
set | grep -E 'DEV_SITE_URL|MULTIDEV_SITE_URL|TERMINUS_'
echo "==========================================="

# Variables
BUILD_DIR=$(pwd)
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
ARTIFACTS_DIR="${ARTIFACTS_FULL_DIR:-/tmp/artifacts}"

# Verify required environment variables
if [ -z "${MULTIDEV_SITE_URL}" ] || [ -z "${DEV_SITE_URL}" ]; then
    echo "ERROR: Required environment variables are not set"
    echo "MULTIDEV_SITE_URL: ${MULTIDEV_SITE_URL:-Not Set}"
    echo "DEV_SITE_URL: ${DEV_SITE_URL:-Not Set}"
    exit 1
fi

echo "Using multidev URL: $MULTIDEV_SITE_URL"
echo "Using dev URL: $DEV_SITE_URL"

# ---------------------------------------------------------------------------
# Cache pre-warming
# ---------------------------------------------------------------------------
# Pantheon multidev appservers sleep when idle and take 30–60s to spin up
# on the first cold hit. The visual-regression tests' own goto() used to
# eat that tax — and combined with the screenshot stability loop, that
# pushed tests past the toHaveScreenshot timeout.
#
# We previously had a browser-based preWarmCache inside the spec file
# (chromium per route × networkidle, then torn down), which DID solve the
# cold-start but doubled total runtime. This bash-level warmer is the
# right tool: parallel HTTP HEAD/GET against every route in test_routes.json
# across BOTH environments, before any Playwright worker starts. That
# amortizes the appserver wake-up across all 22 routes simultaneously
# (8-way parallel by default; bound by Pantheon's connection limit, not
# our sequential goto cost).

# Locate test_routes.json. The CircleCI job persists it at the workspace
# root; fall back to TEST_ROUTES_PATH (project override) or hunt nearby.
find_routes_json() {
  local candidates=(
    "${TEST_ROUTES_PATH:-}"
    "${CIRCLE_WORKING_DIRECTORY:-}/test_routes.json"
    "${BUILD_DIR}/test_routes.json"
    "${SCRIPT_DIR}/../../../test_routes.json"
    "/tmp/workspace/test_routes.json"
  )
  for path in "${candidates[@]}"; do
    if [ -n "${path}" ] && [ -f "${path}" ]; then
      printf '%s\n' "${path}"
      return 0
    fi
  done
  return 1
}

# Emit one URL path per line from test_routes.json. Handles both the new
# `{ routes: { name: url, ... } }` schema and the legacy `{ name: url }`
# top-level shape. Strips any protocol+host so we can prefix env URLs.
extract_route_paths() {
  local routes_file="$1"
  node -e "
    const fs = require('fs');
    const raw = JSON.parse(fs.readFileSync('${routes_file}', 'utf8'));
    const routes = (raw && typeof raw.routes === 'object') ? raw.routes : raw;
    for (const url of Object.values(routes)) {
      try {
        const parsed = new URL(/^https?:\/\//.test(url) ? url : 'http://x' + url);
        process.stdout.write(parsed.pathname + parsed.search + '\n');
      } catch (e) {
        process.stdout.write(String(url) + '\n');
      }
    }
  "
}

# Hit every (env × route) URL in parallel. Best-effort: failed warms just
# log a warning, they don't abort the suite. Per-URL --max-time 90 to
# absorb the cold appserver spin-up; Pantheon typically takes 30–60s on
# the FIRST request and milliseconds thereafter.
warm_caches() {
  local routes_file="$1"
  local start=$(date +%s)
  local urls_file
  urls_file=$(mktemp)

  while IFS= read -r path_only; do
    [ -z "${path_only}" ] && continue
    printf '%s\n' "${DEV_SITE_URL}${path_only}" >> "${urls_file}"
    printf '%s\n' "${MULTIDEV_SITE_URL}${path_only}" >> "${urls_file}"
  done < <(extract_route_paths "${routes_file}")

  if [ ! -s "${urls_file}" ]; then
    echo "  No routes extracted from ${routes_file}; skipping warm."
    rm -f "${urls_file}"
    return 0
  fi

  local total
  total=$(wc -l < "${urls_file}" | tr -d ' ')
  echo "Warming ${total} URLs across both environments (8-way parallel)..."

  # xargs -P 8 fans out 8 concurrent connections. The inner subshell
  # swallows curl errors so a single 5xx or timeout doesn't take down
  # the whole pipeline under `set -e`. Successful warms are silent;
  # only non-2xx/3xx responses log to keep the CI log readable.
  # Note: `if code=$(curl ...)` keeps the failure branch from
  # CONCATENATING with curl's own http_code output (which is what
  # `$(curl ... || echo 000)` does — yielding bogus "000000" strings).
  xargs -P 8 -I {} bash -c '
    url="$1"
    if code=$(curl -sL -o /dev/null -w "%{http_code}" --max-time 90 "${url}" 2>/dev/null); then
      :
    else
      code="000"
    fi
    case "${code}" in
      2*|3*) : ;;
      *) echo "  ⚠️  HTTP ${code} warming: ${url}" ;;
    esac
  ' _ {} < "${urls_file}" || true

  rm -f "${urls_file}"
  local elapsed=$(( $(date +%s) - start ))
  echo "Cache warming complete in ${elapsed}s"
}

echo -e "\nPre-warming Pantheon caches for all routes..."
if ROUTES_FILE=$(find_routes_json); then
  echo "Using routes from: ${ROUTES_FILE}"
  warm_caches "${ROUTES_FILE}"
else
  echo "Warning: could not find test_routes.json — falling back to bare-URL pings"
  curl -sIL -o /dev/null --max-time 90 "$MULTIDEV_SITE_URL" \
    || echo "Warning: Failed to ping $MULTIDEV_SITE_URL"
  curl -sIL -o /dev/null --max-time 90 "$DEV_SITE_URL" \
    || echo "Warning: Failed to ping $DEV_SITE_URL"
fi


# Run the tests
echo -e "\nRunning visual regression tests with Playwright..."

# Check if baseline images exist in the snapshots directory
SNAPSHOT_DIR="./playwright-tests.spec.js-snapshots"

# STAGE 1: Generate reference images from reference environment (DEV)
echo "========================================================="
echo "Step 1: Generating baseline images from reference environment..."
echo "========================================================="

# Clear any existing reference images to ensure clean state
rm -rf playwright-tests.spec.js-snapshots

# Create baseline images from the reference environment.
#
# --retries=0 is intentional and important: in --update-snapshots mode,
# the only way a test can "fail" is if the screenshot stability loop
# can't converge (i.e. the page has un-stabilizable dynamic content like
# auto-advancing carousels). That failure is deterministic — retrying
# will just produce the same failure 30s later. The default --retries=1
# from playwright.config.js would double the cost of every broken page
# in Step 1 with zero chance of recovery. See the comment in
# playwright.config.js → expect.toHaveScreenshot.timeout for how to
# fix perma-failing pages (it's a project-side hideSelectors update,
# not a tool config).
echo "Running test with UPDATE_SNAPSHOTS flag to create baseline images..."
set +e
TESTING_URL=$DEV_SITE_URL npx playwright test --update-snapshots --retries=0
set -e

echo ""
echo "========================================================="
echo "Step 2: Running comparison tests against test environment..."
echo "========================================================="

# Now run comparison tests against the test environment
echo "Running tests without UPDATE_MODE to perform comparisons..."

# Run comparison tests (compare test environment screenshots with baseline).
# Wrap in set +e: under `set -e` a non-zero exit here would abort the script
# BEFORE the retry block below ever ran (that block was effectively dead code).
set +e
TESTING_URL=$MULTIDEV_SITE_URL npx playwright test
TEST_EXIT_CODE=$?
set -e

# Default the final result to the comparison result; the retry below may clear it.
FINAL_EXIT_CODE=$TEST_EXIT_CODE

# Check if there were any failures
if [ $TEST_EXIT_CODE -ne 0 ]; then
  echo ""
  echo "=========================================================="
  echo "Tests failed. Re-running ONLY the failed tests with higher thresholds..."
  echo "(Previously this re-ran all 66 tests — that turned a 33-min pass into"
  echo " a 66+ min one. --last-failed scopes the retry to actual failures.)"
  echo "=========================================================="

  echo "Test report contents:"
  ls -la test-results/

  # Look for diff files to identify which tests failed (informational only).
  # Guard the pipeline with `|| true` so SIGPIPE from sed/uniq can't kill
  # the script under `set -e`.
  echo ""
  echo "Failed tests (with visual differences):"
  find test-results -name "*-diff.png" 2>/dev/null \
    | sed 's/.*\([A-Za-z]\+-[a-z]\+\)-diff\.png.*/\1/' \
    | sort | uniq || true

  echo ""
  echo "=========================================================="
  echo "Retrying failed tests with higher thresholds (--last-failed)..."
  echo "=========================================================="

  # --last-failed reads test-results/.last-run.json from the previous run
  # and runs only the failed specs. Cuts retry-pass wall time proportional
  # to the failure ratio (e.g. 6 failed of 66 → 10x faster retry pass).
  set +e
  TESTING_URL=$MULTIDEV_SITE_URL RETRY_WITH_HIGHER_THRESHOLD=true \
    npx playwright test --last-failed
  RETRY_EXIT_CODE=$?
  set -e

  # The retry is the decisive result: if it clears, the job passes.
  FINAL_EXIT_CODE=$RETRY_EXIT_CODE

  if [ $RETRY_EXIT_CODE -eq 0 ]; then
    echo ""
    echo "=========================================================="
    echo "SUCCESS: All retried tests passed with higher thresholds!"
    echo "=========================================================="
  else
    echo ""
    echo "=========================================================="
    echo "WARNING: Some tests still failed even with higher thresholds."
    echo "         This indicates significant visual differences."
    echo "=========================================================="
  fi
fi

# Copy the report to artifacts directory
echo "Copying test report to artifacts directory..."
mkdir -p "$ARTIFACTS_DIR/playwright-report"
cp -r playwright-report/* "$ARTIFACTS_DIR/playwright-report/" || echo "Warning: Failed to copy report"

# ---------------------------------------------------------------------------
# Failure summary for Slack
# ---------------------------------------------------------------------------
# When the suite ends up failing, write a newline-delimited list of the tests
# that actually failed (parsed from the last run's JSON report). The CircleCI
# job's on_fail step turns this into a Slack message that names the failures
# and links to the diff report — far more actionable than "job failed".
if [ "${FINAL_EXIT_CODE}" -ne 0 ]; then
  echo "Writing failed-test summary for Slack notification..."
  node -e '
    const fs = require("fs");
    let data;
    try { data = JSON.parse(fs.readFileSync("test-results/results.json", "utf8")); }
    catch (e) { process.exit(0); }
    const failed = new Set();
    const walk = (s) => {
      if (!s) return;
      (s.specs || []).forEach((sp) => { if (sp.ok === false) failed.add(sp.title); });
      (s.suites || []).forEach(walk);
    };
    (data.suites || []).forEach(walk);
    fs.writeFileSync("test-results/slack-failures.txt", [...failed].join("\n"));
  ' || echo "Warning: could not parse results.json for Slack summary"
fi

exit "${FINAL_EXIT_CODE}"

